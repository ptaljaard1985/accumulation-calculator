Thumbs.db

# Local tests and scratch
/tmp/

# User's local safety backup of the tool — never commit or modify
Meeting Report/backup.html

# Generated report preview (embeds a specific client's data) — regenerable
Meeting Report/review-report-preview.html

# Generated / client-facing PDFs — never version (binary bloat + client data)
*.pdf

# Raw client review-data exports must never land here. The only committed
# sw-review-data file is the anonymised test fixture in fixtures/. This blocks
# a real export accidentally dropped at the repo root.
/*review-data*.json
